import random
numbers = [random.randint(1, 20) for i in range(3)]
print("Numbers are:", numbers)
secret = random.choice(numbers)
guess = int(input("Guess one number from the list: "))
if guess == secret:
    print("Correct! ")
elif guess > secret:
    print("Too high!")
else:
    print("Too low!")
print("The correct number was:", secret)